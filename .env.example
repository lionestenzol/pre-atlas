# ============================================================
# Mosaic Platform — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# --- AI Providers ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:32b

# --- Service Ports ---
DELTA_KERNEL_PORT=3001
AEGIS_PORT=3002
MIROFISH_PORT=3003
OPENCLAW_PORT=3004
ORCHESTRATOR_PORT=3005
DASHBOARD_PORT=3000

# --- Service URLs (for inter-service communication) ---
DELTA_KERNEL_URL=http://delta-kernel:3001
AEGIS_URL=http://aegis-fabric:3002
MIROFISH_URL=http://mirofish:3003
OPENCLAW_URL=http://openclaw:3004
ORCHESTRATOR_URL=http://orchestrator:3005

# --- PostgreSQL (Aegis Fabric) ---
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_dev_pass
POSTGRES_DB=aegis_admin
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis (Aegis Fabric) ---
REDIS_URL=redis://redis:6379

# --- Neo4j (MiroFish) ---
NEO4J_BOLT_URL=bolt://neo4j:7687
NEO4J_HTTP_URL=http://neo4j:7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish_dev_pass

# --- Aegis Fabric ---
AEGIS_DATA_DIR=.aegis-data
AEGIS_ADMIN_KEY=change-me-to-a-real-key
AEGIS_API_KEY=change-me-to-a-real-key

# --- MiroFish ---
MAX_AGENTS=500
PARALLEL_FACTOR=4

# --- OpenClaw Messaging ---
TELEGRAM_BOT_TOKEN=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# --- Metering ---
FREE_TIER_SECONDS=3600
METERING_DB_PATH=/data/metering.db

# --- Cognitive Sensor ---
COGNITIVE_SENSOR_DIR=/app/services/cognitive-sensor
