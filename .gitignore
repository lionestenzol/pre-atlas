# ===============================
# Pre Atlas .gitignore
# ===============================

# === Node.js ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/
.venv/
*.egg-info/
dist/
build/
*.egg

# === IDE / Editor ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln

# === Build outputs ===
dist/
dist-ssr/
*.local
.cache/
.vite/

# === Large data files (too big for git) ===
# These are source data files, not version controlled
services/cognitive-sensor/results.db
services/cognitive-sensor/memory_db.json
services/cognitive-sensor/conversations.json
services/optogon/data/
*.db-journal

# === Generated state (recreated on run) ===
.delta-fabric/
.aegis-data/

# === Generated HTML (rebuilt by Python pipeline) ===
# Regenerate with: python build_cognitive_atlas.py / python build_cognitive_map.py
services/cognitive-sensor/cognitive_atlas.html
services/cognitive-sensor/cognitive_map.html

# === Generated docs manifest (rebuilt by build_docs_manifest.py) ===
docs_manifest.json
docs_manifest.js

# === Personal data (privacy) ===
# PDF files may contain personal information
*.pdf

# === Logs ===
*.log
logs/

# === Environment files ===
.env
.env.local
.env.*.local
.aegis-tenant-key

# === Temporary files ===
*.tmp
*.temp
*.bak
.pipeline.lock

# === OS generated ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# === Test coverage ===
coverage/
.nyc_output/

# === Optional: keep these if you want to version control state ===
# Uncomment to track delta state:
# !.delta-fabric/entities.json
# !.delta-fabric/deltas.json

# === Windows reserved device names ===
# These phantom files cause issues with git/zip/cross-platform tools
# Ignore 'nul' files anywhere in the repo (Windows reserved name)
**/nul

# === Testing artifacts ===
*.png

# === Archives at root ===
/*.zip
/*.docx

# === Tool artifacts ===
**/.weapon/
.playwright-mcp/
.claude/plan.md
.claude/scheduled_tasks.lock
.mcp.json
**/output/
**/genesis_output/
backups/

# === Worktrees + scratch (added 2026-04-27) ===
.claude/worktrees/
/10485760
/10mb
/tmp/

# === Database blobs (sqlite, etc.) ===
services/cognitive-sensor/atlas.db
services/cognitive-sensor/*.db.bak-*
services/uasc-executor/storage/*.db

# === Vendored binary distributions ===
services/aegis-fabric/redis.zip

# === pytest cache anywhere ===
**/.pytest_cache/

