    {"name": "cors", "version": "^2.8.5", "language": "TypeScript", "used_by": ["delta-kernel", "aegis-fabric"]},
    {"name": "node-cron", "version": "^4.2.1", "language": "TypeScript", "used_by": ["delta-kernel"]},
