    {"name": "Plotly.js", "version": "CDN", "language": "JavaScript", "used_by": ["cognitive_atlas.html"]},
    {"name": "Sigma.js", "version": "CDN", "language": "JavaScript", "used_by": ["cognitive_atlas.html"]}
  ],
