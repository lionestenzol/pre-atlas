{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "AegisWebhook.v1",
  "title": "Aegis Webhook",
  "description": "Webhook subscription for event notifications",
  "type": "object",
  "required": ["tenant_id", "url", "events", "enabled", "created_at"],
  "properties": {
    "tenant_id": { "type": "string", "format": "uuid" },
    "url": { "type": "string", "format": "uri" },
    "events": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "action.completed", "action.denied", "approval.requested", "approval.decided",
          "task.created", "task.completed", "policy.violated", "tenant.mode_changed"
        ]
      }
    },
    "secret_hash": { "type": "string" },
    "enabled": { "type": "boolean" },
    "retry_count": { "type": "integer", "minimum": 0 },
    "last_triggered_at": { "type": ["integer", "null"] },
    "failure_count": { "type": "integer", "minimum": 0 },
    "created_at": { "type": "integer" }
  }
}
