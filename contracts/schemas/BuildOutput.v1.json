{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "BuildOutput.v1",
  "title": "Build Output",
  "description": "Claude Code → Ghost Executor. Per 02_ROSETTA_STONE.md Contract 4 (response side).",
  "type": "object",
  "required": ["task_prompt_id", "completed_at", "status", "artifacts", "summary", "tokens_used", "schema_version"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "task_prompt_id": {
      "type": "string",
      "minLength": 1
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed"]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["file", "diff", "url", "log"]
          },
          "path": { "type": "string" },
          "description": { "type": "string" }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "type": { "enum": ["file", "diff"] }
              }
            },
            "then": { "required": ["path"] }
          }
        ]
      }
    },
    "summary": {
      "type": "string"
    },
    "issues_encountered": {
      "type": "array",
      "items": { "type": "string" }
    },
    "follow_on_tasks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tokens_used": {
      "type": "integer",
      "minimum": 0
    }
  }
}
