{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ContextPackage.v1",
  "title": "Context Package",
  "description": "Output of Site Pull, consumed by Optogon. Per 02_ROSETTA_STONE.md Contract 1.",
  "type": "object",
  "required": ["id", "source", "captured_at", "structure_map", "action_inventory", "token_count", "schema_version"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "enum": ["url", "localhost", "filesystem"]
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "partial": {
      "type": "boolean",
      "description": "True if this is a partial_context_package"
    },
    "coverage_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Required when partial=true"
    },
    "structure_map": {
      "type": "object",
      "required": ["entry_points", "routes"],
      "properties": {
        "entry_points": {
          "type": "array",
          "items": { "type": "string" }
        },
        "routes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "method"],
            "properties": {
              "path": { "type": "string" },
              "method": {
                "type": "string",
                "enum": ["GET", "POST", "PUT", "DELETE", "WS"]
              },
              "params": {
                "type": "array",
                "items": { "type": "string" }
              },
              "inferred_purpose": { "type": "string" }
            }
          }
        },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["page", "service", "api", "worker", "store"]
              },
              "dependencies": {
                "type": "array",
                "items": { "type": "string" }
              },
              "inferred_purpose": { "type": "string" }
            }
          }
        }
      }
    },
    "dependency_graph": {
      "type": "object",
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "type", "name"],
            "properties": {
              "id": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["internal", "external", "package"]
              },
              "name": { "type": "string" }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to", "relationship"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "relationship": {
                "type": "string",
                "enum": ["imports", "calls", "extends", "consumes"]
              }
            }
          }
        }
      }
    },
    "action_inventory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "type", "risk_tier", "reversible"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["api_call", "function", "event", "form_submit"]
          },
          "inputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "outputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "risk_tier": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "reversible": { "type": "boolean" }
        }
      }
    },
    "inferred_state": {
      "type": "object",
      "properties": {
        "auth_required": { "type": "boolean" },
        "data_stores": {
          "type": "array",
          "items": { "type": "string" }
        },
        "environment": {
          "type": "string",
          "enum": ["dev", "staging", "production"]
        },
        "tech_stack": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "token_count": {
      "type": "integer",
      "minimum": 0
    },
    "compression_ratio": {
      "type": "number",
      "minimum": 0
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["partial"],
        "properties": { "partial": { "const": true } }
      },
      "then": { "required": ["coverage_score"] }
    }
  ]
}
