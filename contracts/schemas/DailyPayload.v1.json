{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "DailyPayload.v1",
  "title": "Daily Payload (CycleBoard)",
  "description": "The payload consumed by CycleBoard UI. Current format as of 2026-01-08.",
  "type": "object",
  "required": ["mode", "build_allowed", "primary_action", "generated_at"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Payload schema version (semver)"
    },
    "mode_source": {
      "type": "string",
      "enum": ["cognitive-sensor", "governance-daemon"],
      "description": "Which system proposed this mode"
    },
    "mode": {
      "type": "string",
      "enum": ["CLOSURE", "MAINTENANCE", "BUILD"],
      "description": "Current cognitive mode"
    },
    "build_allowed": {
      "type": "boolean",
      "description": "Whether the user is allowed to start new projects"
    },
    "primary_action": {
      "type": "string",
      "description": "The single most important action for today"
    },
    "open_loops": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Titles of top open loops"
    },
    "open_loop_count": {
      "type": "integer",
      "description": "Total number of detected open loops"
    },
    "closure_ratio": {
      "type": "number",
      "description": "Closure ratio as percentage (0-100)"
    },
    "risk": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH"],
      "description": "Risk level for cognitive overload"
    },
    "generated_at": {
      "type": "string",
      "format": "date",
      "description": "Date payload was generated (YYYY-MM-DD)"
    },
    "life_signals": {
      "type": "object",
      "description": "Multi-domain life signals (energy, finance, skills, network). Optional, absent when no signals ingested.",
      "$ref": "LifeSignals.v1.json"
    },
    "active_constraints": {
      "type": "array",
      "description": "Life-signal constraints currently modifying the routing mode",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "predictions": {
      "type": "object",
      "description": "MiroFish prediction engine results (optional, absent when Neo4j unavailable)",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "unavailable"]
        },
        "top_actions": {
          "type": "array",
          "items": { "type": "object" }
        },
        "pattern_count": {
          "type": "integer"
        },
        "mode_forecast": {
          "type": ["object", "null"]
        },
        "exit_path": {
          "type": ["object", "null"]
        }
      }
    }
  }
}
