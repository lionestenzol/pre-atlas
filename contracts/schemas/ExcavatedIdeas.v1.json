{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ExcavatedIdeas.v1",
  "title": "Excavated Ideas",
  "description": "Raw ideas extracted from conversation analysis by agent_excavator.py",
  "type": "object",
  "required": ["metadata", "ideas"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["generated_at", "total_conversations_scanned", "total_ideas_extracted"],
      "properties": {
        "generated_at": { "type": "string" },
        "total_conversations_scanned": { "type": "integer" },
        "conversations_with_ideas": { "type": "integer" },
        "total_ideas_extracted": { "type": "integer" },
        "skipped_short": { "type": "integer" },
        "skipped_vent": { "type": "integer" }
      }
    },
    "ideas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["idea_id", "convo_id", "idea_text", "category_guess"],
        "properties": {
          "idea_id": { "type": "string" },
          "convo_id": { "type": "string" },
          "convo_title": { "type": "string" },
          "convo_date": { "type": "string" },
          "category_guess": { "type": "string" },
          "idea_text": { "type": "string" },
          "key_quotes": { "type": "array", "items": { "type": "string" } },
          "extraction_signals": {
            "type": "object",
            "properties": {
              "regex_matches": { "type": "array", "items": { "type": "string" } },
              "semantic_similarity": { "type": "number" },
              "has_regex": { "type": "boolean" },
              "has_semantic": { "type": "boolean" }
            }
          },
          "embedding": { "type": "string" }
        }
      }
    }
  }
}
