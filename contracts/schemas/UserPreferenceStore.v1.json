{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "UserPreferenceStore.v1",
  "title": "User Preference Store",
  "description": "Cross-session user memory owned by Atlas, read by all layers. Per 02_ROSETTA_STONE.md Cross-Session User Memory.",
  "type": "object",
  "required": ["user_id", "last_updated", "preferences", "schema_version"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "user_id": {
      "type": "string",
      "minLength": 1
    },
    "last_updated": {
      "type": "string",
      "format": "date-time"
    },
    "preferences": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "value", "confidence", "source", "observed_count", "last_observed"],
        "properties": {
          "key": { "type": "string" },
          "value": {},
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "source": {
            "type": "string",
            "enum": ["explicit", "inferred"]
          },
          "observed_count": {
            "type": "integer",
            "minimum": 0
          },
          "last_observed": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "behavioral_patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pattern", "frequency"],
        "properties": {
          "pattern": { "type": "string" },
          "frequency": {
            "type": "string",
            "enum": ["always", "usually", "sometimes"]
          },
          "context": { "type": "string" },
          "first_observed": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
