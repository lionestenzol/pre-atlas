{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ValidationVerdict.v1",
  "title": "Validation Verdict",
  "description": "Reviewer agent output — validates execution results against spec",
  "type": "object",
  "required": ["verdict_id", "result_id", "task_id", "passed", "evaluated_at"],
  "properties": {
    "verdict_id": { "type": "string", "format": "uuid" },
    "result_id": { "type": "string", "format": "uuid" },
    "task_id": { "type": "string", "format": "uuid" },
    "passed": { "type": "boolean" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "failures": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "step_index": { "type": "integer" },
          "check": { "type": "string", "enum": ["output_shape", "step_count", "error_state", "side_effect", "cost_overrun"] },
          "expected": {},
          "actual": {},
          "severity": { "type": "string", "enum": ["blocking", "warning"] }
        }
      }
    },
    "recommendation": { "type": "string", "enum": ["accept", "retry", "rollback", "escalate"] },
    "evaluated_at": { "type": "integer" }
  }
}
