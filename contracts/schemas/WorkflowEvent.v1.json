{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "WorkflowEvent.v1.json",
  "title": "WorkflowEvent",
  "description": "Event emitted when a workflow runs — daily loop, stall detector, or idea simulation.",
  "type": "object",
  "required": ["event_id", "workflow_type", "timestamp", "status"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "event_id": {
      "type": "string",
      "description": "Unique event identifier"
    },
    "workflow_type": {
      "type": "string",
      "enum": ["daily_loop", "stall_detector", "idea_simulation"],
      "description": "Which workflow produced this event"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the workflow ran"
    },
    "status": {
      "type": "string",
      "enum": ["started", "completed", "failed", "skipped"],
      "description": "Outcome of the workflow run"
    },
    "duration_seconds": {
      "type": "number",
      "minimum": 0,
      "description": "How long the workflow took to execute"
    },
    "steps_completed": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of steps that completed successfully"
    },
    "metadata": {
      "type": "object",
      "description": "Workflow-specific output data",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
