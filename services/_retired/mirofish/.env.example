# MiroFish Configuration
MIROFISH_PORT=3003

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish123

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:32b
OLLAMA_FALLBACK_MODEL=qwen2.5:7b
