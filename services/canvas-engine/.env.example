# canvas-engine · environment template. Copy to .env (gitignored) and edit.
# .env is loaded at startup by src/load-env.ts (fail-soft; no .env is fine).

# --- Image (vision) clone + edit auth -------------------------------------
# Backend selector for the image (vision) clone + edit paths:
#   auto  (default) try the claude CLI first; fall back to the SDK only if the
#                   CLI fails AND ANTHROPIC_API_KEY is set. Best in a normal
#                   terminal where you've run `claude setup-token` / are logged in.
#   cli             use the claude CLI only, never fall back.
#   sdk             use the Anthropic API directly (requires ANTHROPIC_API_KEY).
CANVAS_ENGINE_VISION_BACKEND=auto

# Subscription auth for the CLI in HEADLESS / host-managed sessions, where a
# spawned `claude` can't read your stored login (it 401s). Paste a
# `claude setup-token` value (an sk-ant-oat... OAuth token). Not needed in a
# normal logged-in terminal. Secret — .env is gitignored.
# CLAUDE_CODE_OAUTH_TOKEN=

# API key. Only used by backend=sdk, or as the backend=auto fallback. Leave
# blank to stay key-free (CLI subscription auth).
ANTHROPIC_API_KEY=

# Model for the vision paths. CLI alias (e.g. `sonnet`) or full SDK id. Optional.
# CANVAS_ENGINE_VISION_MODEL=

# --- Service config (all optional; defaults shown) ------------------------
# CANVAS_ENGINE_PORT=3050
# WEB_AUDIT_ROOT=C:/Users/bruke/web-audit
