# --- Delta SCP Compression Queue ---

# Supabase project (Supabase is Postgres). The service key is required because
# the worker writes job state; never expose it to a browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Postgres connection string — only needed by `npm run migrate` to apply the
# schema. Supabase: Project Settings -> Database -> Connection string (URI).
SUPABASE_DB_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres
# Remote migrations verify the DB's TLS cert by default. Set this to true ONLY
# if your provider presents a cert Node can't validate (disables MITM protection).
SCP_PG_INSECURE_TLS=false

# API gateway port (POST /jobs to enqueue, GET /jobs/:id to read result)
SCP_PORT=3012

# Worker polling cadence when the queue is empty (ms)
SCP_POLL_INTERVAL_MS=5000

# Where repos are cloned before compression
SCP_CLONE_DIR=/tmp/delta-scp

# Skip files larger than this (bytes) — they are noise for symbolic compression
SCP_MAX_FILE_BYTES=1048576

# --- API gateway auth (REQUIRED to enable /jobs) ---
# Without this set, POST /jobs and GET /jobs/:id return 503.
# Clients send it as `Authorization: Bearer <key>` or `x-api-key: <key>`.
SCP_API_KEY=

# --- Repo-fetch guardrails (SSRF / abuse protection) ---
# Comma-separated host allowlist; empty = any public host. Private/loopback/
# cloud-metadata hosts are always blocked regardless of this setting.
SCP_ALLOWED_HOSTS=
# Permit local paths / file:// URLs (off by default; handy for testing)
SCP_ALLOW_LOCAL=false
# Hard caps on a single repo before it is rejected mid-walk
SCP_MAX_FILES=20000
SCP_MAX_TOTAL_BYTES=52428800

# --- The flue (v2: routing handoff to the Chainer / droplist) ---
# Where rendered Markdown drops are written when --flue is used. Default is a
# local ./flue-out in the service dir. Point this at droplist's watched inbox to
# wire the two services together (they live in separate repo roots, so this stays
# loose, file-based coupling — no edits to droplist required).
SCP_FLUE_DIR=

# --- Stale-job reaper (crashed-worker recovery) ---
# A job stuck in 'processing' longer than the timeout is re-queued (or parked in
# 'error' once max_attempts is spent). The worker runs the reaper on an interval.
SCP_REAP_TIMEOUT_MS=600000
SCP_REAP_INTERVAL_MS=60000
