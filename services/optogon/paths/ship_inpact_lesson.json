{
  "schema_version": "1.0",
  "id": "ship_inpact_lesson",
  "name": "Ship an inPACT Lesson",
  "version": "1.0",
  "description": "Merges lesson draft into shared ls-* skeleton, verifies UI rules, previews, approves, commits.",
  "entry": {
    "node_id": "entry",
    "match_conditions": [
      { "signal": "intent", "operator": "contains", "value": "ship lesson" }
    ],
    "match_threshold": 0.6,
    "tie_break": "priority"
  },
  "nodes": {
    "entry": {
      "type": "qualify",
      "label": "Gather lesson_number, content_source, ui_theme",
      "qualification": {
        "required": [
          { "key": "lesson_number", "source": "user", "description": "Which lesson number to ship (1-20)" },
          { "key": "content_source", "source": "user", "description": "Path to the draft markdown" },
          { "key": "ui_theme", "source": "user", "description": "Theme for preview render" }
        ],
        "question": {
          "text": "Which lesson number are you shipping, where is the draft, and what theme?",
          "purpose": ["identify target lesson", "locate draft content", "set render theme"],
          "max_asks": 1
        },
        "max_missing_keys_before_split": 3
      },
      "metadata": { "token_budget": 120, "tags": ["ship_inpact_lesson"] }
    },
    "load_skeleton": {
      "type": "execute",
      "label": "Read lesson skeleton",
      "actions": [
        { "id": "read_skeleton", "type": "tool_call", "trigger": "on_entry", "reversible": true, "risk_tier": "low", "retry_strategy": "none" }
      ]
    },
    "validate_content": {
      "type": "gate",
      "label": "Check content_source non-empty"
    },
    "merge": {
      "type": "execute",
      "label": "Merge content into skeleton",
      "actions": [
        { "id": "merge_content", "type": "transform", "trigger": "on_entry", "reversible": true, "risk_tier": "low", "retry_strategy": "none" }
      ]
    },
    "preview": {
      "type": "execute",
      "label": "Render lesson in preview server",
      "actions": [
        { "id": "preview_render", "type": "side_effect", "trigger": "on_entry", "reversible": true, "risk_tier": "low", "retry_strategy": "none" }
      ]
    },
    "em_dash_check": {
      "type": "gate",
      "label": "Scan for em dashes in merged output"
    },
    "approve": {
      "type": "approval",
      "label": "Approve commit",
      "contract": { "required_outputs": ["decision"], "completion_criteria": "user decision received", "failure_mode": "abort" }
    },
    "commit": {
      "type": "execute",
      "label": "Git commit with conventional message",
      "actions": [
        { "id": "git_commit", "type": "side_effect", "trigger": "on_entry", "reversible": false, "risk_tier": "medium", "retry_strategy": "none" }
      ]
    },
    "done": {
      "type": "close",
      "label": "Emit CloseSignal",
      "contract": { "required_outputs": ["commit_sha"], "completion_criteria": "commit landed", "failure_mode": "escalate" }
    }
  },
  "edges": [
    { "from": "entry", "to": "load_skeleton", "condition": "qualified", "priority": 1 },
    { "from": "load_skeleton", "to": "validate_content", "condition": "success", "priority": 1 },
    { "from": "validate_content", "to": "merge", "condition": "content_ok", "priority": 1 },
    { "from": "validate_content", "to": "merge", "condition": "default", "priority": 2 },
    { "from": "merge", "to": "preview", "condition": "success", "priority": 1 },
    { "from": "preview", "to": "em_dash_check", "condition": "success", "priority": 1 },
    { "from": "em_dash_check", "to": "approve", "condition": "clean", "priority": 1 },
    { "from": "em_dash_check", "to": "approve", "condition": "default", "priority": 2 },
    { "from": "approve", "to": "commit", "condition": "approved", "priority": 1 },
    { "from": "approve", "to": "done", "condition": "denied", "priority": 2 },
    { "from": "commit", "to": "done", "condition": "success", "priority": 1 }
  ],
  "close_state": {
    "description": "Lesson shipped and committed",
    "deliverables": ["commit_sha", "lesson_url"],
    "transient_keys": ["lesson_number", "content_source"]
  },
  "defaults": {
    "pacing": { "max_options_shown": 3, "bundle_confirmations": true },
    "inference_confidence_floor": 0.7
  }
}
