# Search-Stack environment configuration
# Copy this file to .env and fill in your API keys.
# .env is git-ignored (root .gitignore line 102).

# --- External agent search providers (Phase 1) ---
# Free tier: 1,000 req/mo. Sign up: https://exa.ai
EXA_API_KEY=

# Free tier: 1,000 req/mo. Sign up: https://tavily.com
TAVILY_API_KEY=

# Free tier: 2,000 req/mo (dev). Sign up: https://brave.com/search/api/
BRAVE_API_KEY=

# Free tier: 500 pages/mo. Sign up: https://firecrawl.dev
FIRECRAWL_API_KEY=

# --- Service config ---
SEARCH_STACK_PORT=3070
SEARCH_STACK_HOST=127.0.0.1

# Cache TTL in seconds (default 1h)
SEARCH_STACK_CACHE_TTL=3600

# Budget thresholds (percent of monthly free tier)
SEARCH_STACK_BUDGET_WARN=70
SEARCH_STACK_BUDGET_BLOCK=80

# --- Provider quotas (monthly free tier req counts) ---
EXA_MONTHLY_QUOTA=1000
TAVILY_MONTHLY_QUOTA=1000
BRAVE_MONTHLY_QUOTA=2000
FIRECRAWL_MONTHLY_QUOTA=500

# --- Optional integrations ---
# When set, /memory/save POSTs results to DropList as intel_drop packets
DROPLIST_INTAKE_URL=

# When set, n8n webhook receives high-priority results
SEARCH_STACK_N8N_URL=

# --- Apify (managed scraping for protected sites) ---
# Sign up: https://console.apify.com/account/integrations
# Free tier: $5 credit/mo. Each enabled actor charges per result.
APIFY_TOKEN=
APIFY_ENABLE_GOOGLE_MAPS=0
APIFY_ENABLE_AMAZON=0
APIFY_ENABLE_INSTAGRAM=0
APIFY_ENABLE_TIKTOK=0
