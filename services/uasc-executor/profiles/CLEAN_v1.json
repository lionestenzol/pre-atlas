{
  "id": "CLEAN",
  "version": 1,
  "description": "System hygiene — clear temp, free disk",
  "steps": [
    {
      "name": "clear_temp",
      "type": "shell",
      "cmd": "del /q/f/s %TEMP%\\* 2>nul",
      "continue_on_error": true,
      "platform": "windows"
    },
    {
      "name": "report_disk",
      "type": "shell",
      "cmd": "wmic logicaldisk get size,freespace,caption",
      "store_as": "disk_report",
      "platform": "windows"
    },
    {
      "name": "log_done",
      "type": "log",
      "message": "System cleaned at {timestamp}",
      "level": "info"
    }
  ],
  "on_success": {
    "type": "log",
    "message": "System cleaned successfully"
  }
}
