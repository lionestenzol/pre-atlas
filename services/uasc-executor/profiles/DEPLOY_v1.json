{
  "id": "DEPLOY",
  "version": 1,
  "description": "Deploy delta-scp-web — real build, verified artifact stamp",
  "inputs": [
    {
      "name": "environment",
      "type": "string",
      "default": "production"
    }
  ],
  "steps": [
    {
      "name": "pre_deploy_check",
      "type": "shell",
      "cmd": "git status --porcelain ../../apps/delta-scp-web",
      "store_as": "dirty_files",
      "fail_if": "dirty_files != ''"
    },
    {
      "name": "build_artifacts",
      "type": "shell",
      "cmd": "cd ../../apps/delta-scp-web && npm run build"
    },
    {
      "name": "push_artifacts",
      "type": "shell",
      "cmd": "cd ../../apps/delta-scp-web && node -e \"const fs=require('fs');const n=fs.readdirSync('dist').length;fs.writeFileSync('.last-deploy.json', JSON.stringify({environment:'{environment}',deployed_at:new Date().toISOString(),file_count:n},null,2));console.log('Deployed '+n+' files to {environment}')\""
    },
    {
      "name": "notify_complete",
      "type": "log",
      "message": "Deploy to {environment} completed at {timestamp}",
      "level": "info"
    }
  ],
  "on_success": {
    "type": "log",
    "message": "Deployment successful"
  },
  "on_failure": {
    "type": "log",
    "message": "Deploy failed — check logs",
    "level": "error"
  }
}
