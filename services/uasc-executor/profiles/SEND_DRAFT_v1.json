{
  "id": "SEND_DRAFT",
  "version": 1,
  "description": "Send a draft notification via ntfy.sh push",
  "inputs": [
    {
      "name": "draft_id",
      "type": "string",
      "description": "Draft entity ID"
    },
    {
      "name": "template_id",
      "type": "string",
      "default": "TEMPLATE_ACK"
    },
    {
      "name": "message_text",
      "type": "string",
      "default": "Acknowledged."
    },
    {
      "name": "target_entity_id",
      "type": "string",
      "default": ""
    }
  ],
  "steps": [
    {
      "name": "push_notification",
      "type": "http",
      "method": "POST",
      "url": "https://ntfy.sh",
      "body": {
        "topic": "atlas-bruke",
        "title": "Atlas: {template_id}",
        "message": "{message_text}",
        "tags": ["robot", "atlas"]
      },
      "expected_status": 200,
      "timeout_seconds": 10,
      "retries": 2
    }
  ],
  "on_success": {
    "type": "log",
    "message": "Draft {draft_id} pushed to phone at {timestamp}"
  },
  "on_failure": {
    "type": "log",
    "message": "Draft push failed for {draft_id}",
    "level": "error"
  }
}
