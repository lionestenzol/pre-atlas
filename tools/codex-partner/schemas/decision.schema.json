{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CodexDecision",
  "description": "Structured decision/recommendation. Used when Claude asks Codex for a second opinion that needs to be parseable, not narrative.",
  "type": "object",
  "additionalProperties": false,
  "required": ["recommendation", "confidence", "rationale", "considered_alternatives", "risks", "preconditions"],
  "properties": {
    "recommendation": {
      "type": "string",
      "maxLength": 200,
      "description": "Single concrete action to take"
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "How sure Codex is about this recommendation"
    },
    "rationale": {
      "type": "string",
      "maxLength": 800,
      "description": "Why this is the right call"
    },
    "considered_alternatives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["option", "rejected_because"],
        "properties": {
          "option": { "type": "string", "maxLength": 200 },
          "rejected_because": { "type": "string", "maxLength": 400 }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string", "maxLength": 200 }
    },
    "preconditions": {
      "type": "array",
      "items": { "type": "string", "maxLength": 200 }
    }
  }
}
